{
  "description": "Full cycle: accept a completion, then a prefetch arrives with more changes.",
  "buffer": {
    "lines": [
      "function add(a, b) {",
      "",
      "}",
      "",
      "function sub(a, b) {",
      "",
      "}"
    ],
    "row": 2,
    "col": 0,
    "viewportTop": 1,
    "viewportBottom": 20
  },
  "steps": [
    {
      "action": "completion",
      "completion": {
        "startLine": 2,
        "endLineInc": 2,
        "lines": ["  return a + b;"]
      },
      "expect": {
        "shown": true,
        "noDeletionGroups": true,
        "bufferAfterAccept": [
          "function add(a, b) {",
          "  return a + b;",
          "}",
          "",
          "function sub(a, b) {",
          "",
          "}"
        ]
      }
    },
    {
      "action": "accept"
    },
    {
      "action": "prefetch",
      "setCursor": { "row": 6, "col": 0 },
      "completion": {
        "startLine": 6,
        "endLineInc": 6,
        "lines": ["  return a - b;"]
      },
      "expect": {
        "shown": true,
        "noDeletionGroups": true,
        "bufferAfterAccept": [
          "function add(a, b) {",
          "  return a + b;",
          "}",
          "",
          "function sub(a, b) {",
          "  return a - b;",
          "}"
        ]
      }
    }
  ]
}
