{
  "description": "Completion expanding 1 line into 3 lines of implementation via the completion action.",
  "buffer": {
    "lines": [
      "def main():",
      "    pass",
      "",
      "main()"
    ],
    "row": 2,
    "col": 4,
    "viewportTop": 1,
    "viewportBottom": 20
  },
  "steps": [
    {
      "action": "completion",
      "completion": {
        "startLine": 2,
        "endLineInc": 2,
        "lines": ["    x = 10", "    y = 20", "    print(x + y)"]
      },
      "expect": {
        "shown": true,
        "noDeletionGroups": true,
        "bufferAfterAccept": [
          "def main():",
          "    x = 10",
          "    y = 20",
          "    print(x + y)",
          "",
          "main()"
        ]
      }
    }
  ]
}
