{
  "description": "Prefetch completion inserting for-loop body (1 old line -> 3 new lines) should not delete unrelated lines below. Reproduces issue #51.",
  "buffer": {
    "lines": [
      "var arra = [1, 2, 3];",
      "",
      "function test() {",
      "  for (var i = 0; i < arra.length; i++) {",
      "}",
      "",
      "function test2() {",
      "  console.log(arra);",
      "}",
      "  "
    ],
    "row": 4,
    "col": 41,
    "viewportTop": 1,
    "viewportBottom": 50
  },
  "steps": [
    {
      "action": "prefetch",
      "completion": {
        "startLine": 5,
        "endLineInc": 5,
        "lines": ["    console.log(arra[i]);", "  }", "}"]
      },
      "expect": {
        "shown": true,
        "noDeletionGroups": true,
        "bufferAfterAccept": [
          "var arra = [1, 2, 3];",
          "",
          "function test() {",
          "  for (var i = 0; i < arra.length; i++) {",
          "    console.log(arra[i]);",
          "  }",
          "}",
          "",
          "function test2() {",
          "  console.log(arra);",
          "}",
          "  "
        ]
      }
    }
  ]
}
