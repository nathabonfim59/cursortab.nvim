-- expected --
from dataclasses import dataclass


@dataclass
class Article:
    title: str
    tags: list[str]


def render_header(article: Article) -> str:
    lines = [f"# {article.title}"]
    if article.tags:
        lines.append(f"Tags: {', '.join(t.lower() for t in article.tags)}")
    return "\n".join(lines)


def search_by_tag(articles: list[Article], tag: str) -> list[Article]:
    return [a for a in articles if a.tags == tag]

