-- expected --
package queue

import "fmt"

type Message struct {
	ID   string
	Body []byte
}

func (q *Queue) Send(msgs []Message) error {
	for _, msg := range msgs {
		if err := q.conn.Publish(msg.Body); err != nil {
			return fmt.Errorf("publish %s: %w", msg.ID, err)
		}
		q.sent++
	}
	return nil
}

