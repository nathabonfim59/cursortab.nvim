-- expected --
#[derive(Clone)]
pub struct User {
    pub id: u32,
    pub name: String,
    pub tags: Vec<String>,
}

pub struct Store {
    users: Vec<User>,
}

impl Store {
    pub fn find_all(&self, tag: &str) -> Vec<User> {
        self.users
            .iter()
            .filter(|u| u.tags.iter().any(|t| t == tag))
            .cloned()
            .collect()
    }

    pub fn print_matching(&self, tag: &str) {
        for user in self.find_all(tag) {
            println!("{}: {}", user.id, user.name);
        }
    }
}

