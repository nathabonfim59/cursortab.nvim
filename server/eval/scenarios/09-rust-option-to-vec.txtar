-- buffer.txt --
#[derive(Clone)]
pub struct User {
    pub id: u32,
    pub name: String,
    pub tags: Vec<String>,
}

pub struct Store {
    users: Vec<User>,
}

impl Store {
    pub fn find_all(&self, tag: &str) -> Vec<User> {
        self.users
            .iter()
            .find(|u| u.tags.iter().any(|t| t == tag))
            .cloned()
    }

    pub fn print_matching(&self, tag: &str) {
        let user = self.find_all(tag).unwrap();
        println!("{}: {}", user.id, user.name);
    }
}
