-- buffer.txt --
package server

import (
	"log/slog"
	"time"
)

type Config struct {
	Host         string
	Port         int
	ReadTimeout  time.Duration
	WriteTimeout time.Duration
	Logger       *slog.Logger
}

type Server struct {
	cfg Config
}

func New(cfg Config) *Server {
	return &Server{cfg: cfg}
}

func Run() *Server {
	logger := slog.Default()
	srv := New("localhost", 8080, 5*time.Second, 10*time.Second, logger)
	return srv
}
