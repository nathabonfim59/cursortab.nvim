-- expected --
interface Row {
  id: number;
  name: string;
}

export class DB {
  async query(sql: string): Promise<Row[]> {
    // ...returns rows from the underlying driver
    return [];
  }
}

export async function loadNames(db: DB): Promise<string[]> {
  const rows = await db.query("SELECT id, name FROM users");
  return rows.map((r) => r.name);
}

