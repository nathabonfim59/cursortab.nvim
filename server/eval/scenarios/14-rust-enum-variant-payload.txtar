-- expected --
use std::fmt;

pub enum State {
    Connecting,
    Connected(String),
    Disconnected { reason: String },
}

impl fmt::Display for State {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            State::Connecting => write!(f, "connecting"),
            State::Connected(host) => write!(f, "connected to {host}"),
            State::Disconnected { reason } => write!(f, "disconnected: {reason}"),
        }
    }
}

