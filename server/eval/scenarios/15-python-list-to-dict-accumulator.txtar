-- buffer.txt --
def tally_words(text: str) -> dict[str, int]:
    counts: dict[str, int] = {}
    for word in text.lower().split():
        found = False
        for i, (w, c) in enumerate(counts):
            if w == word:
                counts[i] = (w, c + 1)
                found = True
                break
        if not found:
            counts.append((word, 1))
    return counts
