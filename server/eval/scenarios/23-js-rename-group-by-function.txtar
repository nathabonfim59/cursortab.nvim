function filterByStatus(items, status) {
    return items.filter(item => item.status === status);
}

function groupByCat(items) {
    return items.reduce((groups, item) => {
        const key = item.status;
        (groups[key] = groups[key] || []).push(item);
        return groups;
    }, {});
}
