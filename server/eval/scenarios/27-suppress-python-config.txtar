from dataclasses import dataclass, field


@dataclass
class Config:
    host: str = "localhost"
    port: int = 8080
    debug: bool = False
    tags: list[str] = field(default_factory=list)

    def address(self) -> str:
        return f"{self.host}:{self.port}"
