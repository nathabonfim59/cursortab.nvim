import logging
from functools import wraps

logger = logging.getLogger(__name__)


def log_calls(func):
    @wraps(func)
    def wrapper(*args, **kwargs):
        logger.info("calling %s", func.__name__)
        result = func(*args, **kwargs)
        logger.info("%s returned %r", func.__name__, result)
        return result
    return wrapper
