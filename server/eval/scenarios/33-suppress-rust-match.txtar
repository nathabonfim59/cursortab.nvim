pub fn describe(value: Option<i32>) -> String {
    match value {
        Some(n) if n < 0 => format!("negative: {n}"),
        Some(0) => "zero".to_string(),
        Some(n) => format!("positive: {n}"),
        None => "absent".to_string(),
    }
}
