-- buffer.txt --
class Animal:
    def __init__(self, name: str, sound: str):
        self.name = name
        self.sound = sound

    def speak(self) -> str:
        return f"{self.name} says {self.sound}"

    def describe(self) -> str:
        return f"{self.name} ({type(self).__name__})"


class Dog:
    def __init__(self, name: str, tricks: list[str]):
        self.animal = Animal(name, "woof")
        self.tricks = tricks

    def greet(self, person: str) -> str:
        return f"{self.speak()} to {person}!"

    def show_tricks(self) -> str:
        header = self.describe()
        lines = [f"  - {t}" for t in self.tricks]
        return f"{header} knows:\n" + "\n".join(lines)
